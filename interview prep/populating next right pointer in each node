class Solution {
public:
    Node* connect(Node* root) {
        if(!root) return nullptr;
        queue<Node*> q;
        Node* head = root;
        q.push(head);
        while(!q.empty()) {
            Node* right = new Node();
            right = nullptr;
            for(int i = q.size(); i > 0; i--){
                Node* curr = q.front();
                q.pop();
                curr->next = right;
                right = curr;
                if(curr->right) {
                    q.push(curr->right);
                    q.push(curr->left);
                }
            }
        }
        return root;
    }
};
