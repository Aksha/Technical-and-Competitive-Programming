Hard to build the adjacency list for this question:


#include <iostream>
#include <vector>
#include <unordered_map>
#include<queue>
using namespace std;

int main() {
    vector<vector<int>> input = {
        {1, 3, 5},
        {3, 10}
    };

    unordered_map<int, vector<int>> adj;

    int maxNode = 0;
    for (const auto& group : input) {
        int n = group.size();

        // Connect every pair inside the group
        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {

                int u = group[i];
                int v = group[j];

                adj[u].push_back(v);
                adj[v].push_back(u);
            }
        }
    }
    for (const auto& group : input) {
        for (int x : group) {
            maxNode = max(maxNode, x);
        }
    }

    vector<bool> visited(maxNode+1, 0);
    vector<int> distance(maxNode+1, -1);

    int source = 1;
    int destination = 10;



    queue<int> Q;
    Q.push(source);
    visited[source] = 1;
    while (!Q.empty()) {
        int curr = Q.front();
        Q.pop();
        if (curr == destination) {
            cout << " The distance is : " << distance[curr] << endl;
            return distance[curr];
        }
        for (int i = 0; i < adj[curr].size(); i++) {
            if (visited[adj[curr][i]] == 0) {
                distance[adj[curr][i]] = distance[curr] + 1;
                visited[adj[curr][i]] = 1;
                Q.push(adj[curr][i]);
            }
        }
    }
    return distance[destination];
}
