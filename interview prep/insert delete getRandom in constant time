class RandomizedSet {
public:
    unordered_map<int,int> hmap_index;
    vector<int> arr;
    RandomizedSet() {
        
    }
    
    bool insert(int val) {
        if(hmap_index.find(val) != hmap_index.end()) {
            return false;
        }
        else {
            arr.push_back(val);
            int index = arr.size() - 1;
            hmap_index.insert(make_pair(val,index));
            return true;
        }
    }
    
    bool remove(int val) {
        if(hmap_index.find(val) != hmap_index.end()) {//find element, if found, remove both in array and hashmap. return true. 
            //map remove by key using erase. constant time.
            //erase from array. find the index. resize array. swap out the current element with the last index and resize again.
            int curr_index = hmap_index[val];
            arr[curr_index] = arr.back();
            arr.pop_back();
            hmap_index[arr[curr_index]] = curr_index;
            hmap_index.erase(val);
            return true;
        }
        else {
            return false;
        }
    }
    
    int getRandom() {
        int random =  rand() % arr.size();
        return arr[random];
    }
};

