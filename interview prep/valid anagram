class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.size() != t.size())
            return false;
        unordered_map<char,int> umap;
        for(char c : s) {
            umap[c]++;
        }
        for(char c:t) {
            if(umap.find(c) == umap.end()) {
                return false;
            }
            else {
                if(umap[c] == 0) {
                    return false;
                }
                else {
                    umap[c]--;
                    if(umap[c] == 0) {
                        umap.erase(c);
                    }
                }
            }
        }
        return true;
    }
};
